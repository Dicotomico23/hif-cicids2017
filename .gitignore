# Datasets are downloaded at run time, never committed (too large for git).
data/*
!data/README.md
!data/download.py
*.csv
*.zip

# Packaged dataset archive (uploaded to Zenodo / GitHub Release, not committed).
dist/

# Third-party code fetched at run time (e.g. Marteau's GPL HIF). Not vendored
# so this MIT repo stays MIT-clean.
.external/

# Generated results (keep the directory and figures placeholder if you wish).
results/*.csv
results/*.json

# Python
__pycache__/
*.pyc
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.env

# OS / editors
.DS_Store
.idea/
.vscode/

# LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.fls
paper/*.fdb_latexmk
